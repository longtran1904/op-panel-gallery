{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/panels/layout,_N_T_/panels/[slug]/layout,_N_T_/panels/[slug]/page,_N_T_/panels/wall-of-titans"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/panels/$d$slug/__PAGE__",
    "/panels/$d$slug",
    "/panels",
    "/_index",
    "/_head"
  ]
}